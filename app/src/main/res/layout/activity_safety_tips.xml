<?xml version="1.0" encoding="utf-8"?>
<!-- RapidGuard | Screen 14: Safety Tips + AI Risk Heatmap | Group 41 -->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/safetyTipsRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient_radial"
    tools:context=".SafetyTipsActivity">

    <!-- Grid overlay -->
    <View
        android:id="@+id/gridOverlay"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@drawable/bg_grid_overlay"
        android:alpha="0.04"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Scrollable content -->
    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:scrollbars="none"
        android:clipToPadding="false"
        android:paddingBottom="@dimen/bottom_nav_height"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/bottomNav"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="@dimen/spacing_xl">

            <!-- ===== TOP BAR ===== -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="@dimen/spacing_lg"
                android:paddingEnd="@dimen/spacing_lg"
                android:paddingTop="@dimen/spacing_xxl">

                <ImageButton
                    android:id="@+id/btnBack"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_arrow_back"
                    android:background="@drawable/bg_card_dark"
                    android:contentDescription="@string/cd_back"
                    android:padding="@dimen/spacing_sm"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent" />

                <TextView
                    android:id="@+id/tvScreenLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/tips_label"
                    android:textSize="@dimen/text_micro"
                    android:fontFamily="@font/poppins_medium"
                    android:textColor="@color/sos_core_red"
                    android:letterSpacing="0.12"
                    android:textAllCaps="true"
                    app:layout_constraintTop_toTopOf="@id/btnBack"
                    app:layout_constraintBottom_toBottomOf="@id/btnBack"
                    app:layout_constraintStart_toEndOf="@id/btnBack"
                    android:layout_marginStart="@dimen/spacing_md" />

                <!-- Last updated badge -->
                <TextView
                    android:id="@+id/tvLastUpdated"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/tips_last_updated"
                    android:textSize="@dimen/text_micro"
                    android:fontFamily="@font/poppins_medium"
                    android:textColor="@color/text_muted"
                    android:background="@drawable/bg_badge_dark"
                    android:paddingStart="@dimen/spacing_sm"
                    android:paddingEnd="@dimen/spacing_sm"
                    android:paddingTop="@dimen/spacing_xxs"
                    android:paddingBottom="@dimen/spacing_xxs"
                    app:layout_constraintTop_toTopOf="@id/btnBack"
                    app:layout_constraintBottom_toBottomOf="@id/btnBack"
                    app:layout_constraintEnd_toEndOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Heading -->
            <TextView
                android:id="@+id/tvHeading"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/tips_heading"
                android:textSize="@dimen/text_heading"
                android:fontFamily="@font/poppins_bold"
                android:textColor="@color/white"
                android:lineSpacingMultiplier="1.2"
                android:paddingStart="@dimen/spacing_lg"
                android:paddingEnd="@dimen/spacing_lg"
                android:layout_marginTop="@dimen/spacing_lg" />

            <TextView
                android:id="@+id/tvSubheading"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/tips_subheading"
                android:textSize="@dimen/text_body"
                android:fontFamily="@font/poppins_regular"
                android:textColor="@color/text_muted"
                android:paddingStart="@dimen/spacing_lg"
                android:paddingEnd="@dimen/spacing_lg"
                android:layout_marginTop="@dimen/spacing_xs" />

            <!-- Red divider -->
            <View
                android:layout_width="@dimen/divider_width"
                android:layout_height="@dimen/divider_height"
                android:background="@drawable/bg_red_divider"
                android:layout_marginStart="@dimen/spacing_lg"
                android:layout_marginTop="@dimen/spacing_lg" />

            <!-- ===== AI RISK LEVEL CARD ===== -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardAIRisk"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/spacing_lg"
                android:layout_marginEnd="@dimen/spacing_lg"
                android:layout_marginTop="@dimen/spacing_xl"
                app:cardBackgroundColor="@color/card_dark"
                app:cardCornerRadius="@dimen/card_radius_md"
                app:cardElevation="0dp">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="@dimen/spacing_lg">

                    <!-- AI chip label -->
                    <TextView
                        android:id="@+id/tvAIChip"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/tips_ai_chip"
                        android:textSize="@dimen/text_micro"
                        android:fontFamily="@font/poppins_semibold"
                        android:textColor="@color/sos_core_red"
                        android:background="@drawable/bg_status_danger"
                        android:paddingStart="@dimen/spacing_sm"
                        android:paddingEnd="@dimen/spacing_sm"
                        android:paddingTop="@dimen/spacing_xxs"
                        android:paddingBottom="@dimen/spacing_xxs"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent" />

                    <!-- Risk level heading -->
                    <TextView
                        android:id="@+id/tvRiskLevelHeading"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="@string/tips_risk_level_heading"
                        android:textSize="20sp"
                        android:fontFamily="@font/poppins_bold"
                        android:textColor="@color/status_warning"
                        app:layout_constraintTop_toBottomOf="@id/tvAIChip"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toStartOf="@id/riskScoreCircle"
                        android:layout_marginTop="@dimen/spacing_sm" />

                    <!-- Risk description -->
                    <TextView
                        android:id="@+id/tvRiskDescription"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="@string/tips_risk_description"
                        android:textSize="@dimen/text_micro"
                        android:fontFamily="@font/poppins_regular"
                        android:textColor="@color/text_muted"
                        android:lineSpacingMultiplier="1.5"
                        app:layout_constraintTop_toBottomOf="@id/tvRiskLevelHeading"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toStartOf="@id/riskScoreCircle"
                        android:layout_marginTop="@dimen/spacing_xs"
                        android:layout_marginEnd="@dimen/spacing_md" />

                    <!-- Risk score circle -->
                    <androidx.cardview.widget.CardView
                        android:id="@+id/riskScoreCircle"
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        app:cardBackgroundColor="@color/card_inner_glow"
                        app:cardCornerRadius="32dp"
                        app:cardElevation="0dp"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:gravity="center">

                            <TextView
                                android:id="@+id/tvRiskScore"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/tips_risk_score"
                                android:textSize="22sp"
                                android:fontFamily="@font/poppins_extrabold"
                                android:textColor="@color/status_warning" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/tips_risk_score_label"
                                android:textSize="@dimen/text_micro"
                                android:fontFamily="@font/poppins_regular"
                                android:textColor="@color/text_muted"
                                android:gravity="center" />

                        </LinearLayout>

                    </androidx.cardview.widget.CardView>

                    <!-- Bottom: trend stats row -->
                    <LinearLayout
                        android:id="@+id/trendRow"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="@dimen/spacing_lg"
                        android:weightSum="3"
                        app:layout_constraintTop_toBottomOf="@id/tvRiskDescription"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toStartOf="@id/riskScoreCircle"
                        android:layout_marginEnd="@dimen/spacing_md">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/tips_trend_incidents"
                                android:textSize="13sp"
                                android:fontFamily="@font/poppins_bold"
                                android:textColor="@color/status_warning" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/tips_trend_incidents_label"
                                android:textSize="@dimen/text_micro"
                                android:fontFamily="@font/poppins_regular"
                                android:textColor="@color/text_muted" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/tips_trend_change"
                                android:textSize="13sp"
                                android:fontFamily="@font/poppins_bold"
                                android:textColor="@color/status_danger" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/tips_trend_change_label"
                                android:textSize="@dimen/text_micro"
                                android:fontFamily="@font/poppins_regular"
                                android:textColor="@color/text_muted" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/tips_trend_radius"
                                android:textSize="13sp"
                                android:fontFamily="@font/poppins_bold"
                                android:textColor="@color/white" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/tips_trend_radius_label"
                                android:textSize="@dimen/text_micro"
                                android:fontFamily="@font/poppins_regular"
                                android:textColor="@color/text_muted" />
                        </LinearLayout>

                    </LinearLayout>

                </androidx.constraintlayout.widget.ConstraintLayout>

            </androidx.cardview.widget.CardView>

            <!-- ===== HEATMAP PLACEHOLDER ===== -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/tips_heatmap_label"
                android:textSize="@dimen/text_caption"
                android:fontFamily="@font/poppins_semibold"
                android:textColor="@color/text_light"
                android:paddingStart="@dimen/spacing_lg"
                android:paddingEnd="@dimen/spacing_lg"
                android:layout_marginTop="@dimen/spacing_xl" />

            <androidx.cardview.widget.CardView
                android:id="@+id/cardHeatmap"
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:layout_marginStart="@dimen/spacing_lg"
                android:layout_marginEnd="@dimen/spacing_lg"
                android:layout_marginTop="@dimen/spacing_sm"
                app:cardBackgroundColor="@color/card_dark"
                app:cardCornerRadius="@dimen/card_radius_md"
                app:cardElevation="0dp">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <!-- Heatmap grid bg -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_grid_overlay"
                        android:alpha="0.06" />

                    <!-- Heatmap colour blobs (placeholder) -->
                    <View
                        android:id="@+id/heatZoneRed"
                        android:layout_width="100dp"
                        android:layout_height="100dp"
                        android:background="@drawable/bg_heatmap_red"
                        android:layout_gravity="center_vertical"
                        android:layout_marginStart="40dp" />

                    <View
                        android:id="@+id/heatZoneOrange"
                        android:layout_width="80dp"
                        android:layout_height="80dp"
                        android:background="@drawable/bg_heatmap_orange"
                        android:layout_gravity="center"
                        android:layout_marginStart="120dp" />

                    <View
                        android:id="@+id/heatZoneGreen"
                        android:layout_width="70dp"
                        android:layout_height="70dp"
                        android:background="@drawable/bg_heatmap_green"
                        android:layout_gravity="center_vertical|end"
                        android:layout_marginEnd="30dp" />

                    <!-- Heatmap overlay label -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="@drawable/bg_card_dark"
                        android:padding="@dimen/spacing_sm"
                        android:layout_gravity="top|start"
                        android:layout_margin="@dimen/spacing_sm">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/tips_heatmap_title"
                            android:textSize="@dimen/text_micro"
                            android:fontFamily="@font/poppins_semibold"
                            android:textColor="@color/white" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/tips_heatmap_sub"
                            android:textSize="@dimen/text_micro"
                            android:fontFamily="@font/poppins_regular"
                            android:textColor="@color/text_muted" />

                    </LinearLayout>

                    <!-- High-risk area explanation overlay -->
                    <androidx.cardview.widget.CardView
                        android:id="@+id/highRiskExplain"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="bottom|start"
                        android:layout_margin="@dimen/spacing_sm"
                        app:cardBackgroundColor="#CC0A1628"
                        app:cardCornerRadius="@dimen/card_radius_sm"
                        app:cardElevation="0dp">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:padding="@dimen/spacing_sm">

                            <View
                                android:layout_width="8dp"
                                android:layout_height="8dp"
                                android:background="@drawable/bg_dot_red"
                                android:layout_marginEnd="@dimen/spacing_xs" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/tips_high_risk_area"
                                android:textSize="@dimen/text_micro"
                                android:fontFamily="@font/poppins_medium"
                                android:textColor="@color/sos_light_red" />

                        </LinearLayout>

                    </androidx.cardview.widget.CardView>

                </FrameLayout>

            </androidx.cardview.widget.CardView>

            <!-- ===== HEATMAP LEGEND ===== -->
            <LinearLayout
                android:id="@+id/legendRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="@dimen/spacing_lg"
                android:paddingEnd="@dimen/spacing_lg"
                android:layout_marginTop="@dimen/spacing_md"
                android:weightSum="3">

                <!-- High risk -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <View
                        android:layout_width="10dp"
                        android:layout_height="10dp"
                        android:background="@drawable/bg_dot_red"
                        android:layout_marginEnd="@dimen/spacing_xs" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/legend_high"
                        android:textSize="@dimen/text_micro"
                        android:fontFamily="@font/poppins_regular"
                        android:textColor="@color/text_muted" />
                </LinearLayout>

                <!-- Moderate risk -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <View
                        android:layout_width="10dp"
                        android:layout_height="10dp"
                        android:background="@drawable/bg_dot_amber"
                        android:layout_marginEnd="@dimen/spacing_xs" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/legend_moderate"
                        android:textSize="@dimen/text_micro"
                        android:fontFamily="@font/poppins_regular"
                        android:textColor="@color/text_muted" />
                </LinearLayout>

                <!-- Low risk -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <View
                        android:layout_width="10dp"
                        android:layout_height="10dp"
                        android:background="@drawable/bg_dot_green"
                        android:layout_marginEnd="@dimen/spacing_xs" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/legend_low"
                        android:textSize="@dimen/text_micro"
                        android:fontFamily="@font/poppins_regular"
                        android:textColor="@color/text_muted" />
                </LinearLayout>

            </LinearLayout>

            <!-- ===== SAFETY TIPS SECTION ===== -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/tips_section_label"
                android:textSize="@dimen/text_caption"
                android:fontFamily="@font/poppins_semibold"
                android:textColor="@color/text_light"
                android:paddingStart="@dimen/spacing_lg"
                android:paddingEnd="@dimen/spacing_lg"
                android:layout_marginTop="@dimen/spacing_xl" />

            <!-- Tips cards container -->
            <LinearLayout
                android:id="@+id/tipsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="@dimen/spacing_lg"
                android:paddingEnd="@dimen/spacing_lg"
                android:layout_marginTop="@dimen/spacing_md">

                <!-- Tip 1 -->
                <include
                    android:id="@+id/tipCard1"
                    layout="@layout/item_safety_tip_card" />

                <!-- Tip 2 -->
                <include
                    android:id="@+id/tipCard2"
                    layout="@layout/item_safety_tip_card" />

                <!-- Tip 3 -->
                <include
                    android:id="@+id/tipCard3"
                    layout="@layout/item_safety_tip_card" />

                <!-- Tip 4 -->
                <include
                    android:id="@+id/tipCard4"
                    layout="@layout/item_safety_tip_card" />

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- ===== BOTTOM NAVIGATION ===== -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="0dp"
        android:layout_height="@dimen/bottom_nav_height"
        android:background="@drawable/bg_nav_background"
        app:menu="@menu/bottom_nav_menu"
        app:itemIconTint="@color/nav_item_color"
        app:itemTextColor="@color/nav_item_color"
        app:itemActiveIndicatorColor="@color/nav_active_indicator"
        app:labelVisibilityMode="labeled"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>