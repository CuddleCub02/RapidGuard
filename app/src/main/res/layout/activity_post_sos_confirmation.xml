<?xml version="1.0" encoding="utf-8"?>
<!-- RapidGuard | Screen 7: Post-SOS Confirmation Screen | Group 41 -->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/postSosRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient_radial"
    tools:context=".PostSosConfirmationActivity">

    <!-- Grid overlay -->
    <View
        android:id="@+id/gridOverlay"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@drawable/bg_grid_overlay"
        android:alpha="0.04"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Scrollable content -->
    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:scrollbars="none"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/spacing_lg"
            android:paddingEnd="@dimen/spacing_lg"
            android:paddingBottom="@dimen/spacing_xxl">

            <!-- ===== HEADER ===== -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="@dimen/spacing_xxl">

                <!-- Home button top-left -->
                <ImageButton
                    android:id="@+id/btnHome"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_nav_home"
                    android:background="@drawable/bg_card_dark"
                    android:contentDescription="@string/cd_go_home"
                    android:padding="@dimen/spacing_sm"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent" />

                <!-- Incident ref number top-right -->
                <TextView
                    android:id="@+id/tvIncidentRef"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/post_sos_ref_placeholder"
                    android:textSize="@dimen/text_micro"
                    android:fontFamily="@font/poppins_semibold"
                    android:textColor="@color/text_muted"
                    android:background="@drawable/bg_badge_dark"
                    android:paddingStart="@dimen/spacing_sm"
                    android:paddingEnd="@dimen/spacing_sm"
                    android:paddingTop="@dimen/spacing_xxs"
                    android:paddingBottom="@dimen/spacing_xxs"
                    app:layout_constraintTop_toTopOf="@id/btnHome"
                    app:layout_constraintBottom_toBottomOf="@id/btnHome"
                    app:layout_constraintEnd_toEndOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- ===== HERO: HELP IS ON THE WAY ===== -->

            <!-- Green pulse check illustration -->
            <FrameLayout
                android:id="@+id/heroIllustration"
                android:layout_width="110dp"
                android:layout_height="110dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="@dimen/spacing_xl">

                <!-- Outer pulse ring -->
                <View
                    android:id="@+id/heroPulse2"
                    android:layout_width="110dp"
                    android:layout_height="110dp"
                    android:background="@drawable/bg_success_ring"
                    android:alpha="0.15"
                    android:layout_gravity="center" />

                <!-- Inner pulse ring -->
                <View
                    android:id="@+id/heroPulse1"
                    android:layout_width="84dp"
                    android:layout_height="84dp"
                    android:background="@drawable/bg_success_ring"
                    android:alpha="0.25"
                    android:layout_gravity="center" />

                <!-- Check circle -->
                <ImageView
                    android:id="@+id/ivHeroCheck"
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:src="@drawable/ic_check_circle"
                    android:contentDescription="@string/cd_alert_sent"
                    android:layout_gravity="center" />

            </FrameLayout>

            <!-- "Help is on the way!" heading -->
            <TextView
                android:id="@+id/tvHelpHeading"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/post_sos_heading"
                android:textSize="24sp"
                android:fontFamily="@font/poppins_extrabold"
                android:textColor="@color/white"
                android:gravity="center"
                android:layout_marginTop="@dimen/spacing_lg" />

            <!-- Subtext -->
            <TextView
                android:id="@+id/tvHelpSubtext"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/post_sos_subtext"
                android:textSize="@dimen/text_caption"
                android:fontFamily="@font/poppins_regular"
                android:textColor="@color/text_muted"
                android:gravity="center"
                android:lineSpacingMultiplier="1.5"
                android:layout_marginTop="@dimen/spacing_xs" />

            <!-- Red divider -->
            <View
                android:layout_width="@dimen/divider_width"
                android:layout_height="@dimen/divider_height"
                android:background="@drawable/bg_red_divider"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="@dimen/spacing_lg" />

            <!-- ===== INCIDENT SUMMARY CARD ===== -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardIncidentSummary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_lg"
                app:cardBackgroundColor="@color/card_dark"
                app:cardCornerRadius="@dimen/card_radius_md"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_lg">

                    <!-- Row: Incident ref -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingBottom="@dimen/spacing_md">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/post_sos_label_ref"
                            android:textSize="@dimen/text_micro"
                            android:fontFamily="@font/poppins_regular"
                            android:textColor="@color/text_muted" />

                        <TextView
                            android:id="@+id/tvRefNumber"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/post_sos_ref_number"
                            android:textSize="@dimen/text_caption"
                            android:fontFamily="@font/poppins_bold"
                            android:textColor="@color/white" />

                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="0.5dp"
                        android:background="@color/rim_border"
                        android:layout_marginBottom="@dimen/spacing_md" />

                    <!-- Row: Emergency type -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingBottom="@dimen/spacing_md">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/post_sos_label_type"
                            android:textSize="@dimen/text_micro"
                            android:fontFamily="@font/poppins_regular"
                            android:textColor="@color/text_muted" />

                        <TextView
                            android:id="@+id/tvEmergencyType"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/post_sos_type_placeholder"
                            android:textSize="@dimen/text_caption"
                            android:fontFamily="@font/poppins_semibold"
                            android:textColor="@color/white" />

                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="0.5dp"
                        android:background="@color/rim_border"
                        android:layout_marginBottom="@dimen/spacing_md" />

                    <!-- Row: Timestamp -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingBottom="@dimen/spacing_md">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/post_sos_label_time"
                            android:textSize="@dimen/text_micro"
                            android:fontFamily="@font/poppins_regular"
                            android:textColor="@color/text_muted" />

                        <TextView
                            android:id="@+id/tvTimestamp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/post_sos_time_placeholder"
                            android:textSize="@dimen/text_caption"
                            android:fontFamily="@font/poppins_semibold"
                            android:textColor="@color/white" />

                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="0.5dp"
                        android:background="@color/rim_border"
                        android:layout_marginBottom="@dimen/spacing_md" />

                    <!-- Row: Location -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/post_sos_label_location"
                            android:textSize="@dimen/text_micro"
                            android:fontFamily="@font/poppins_regular"
                            android:textColor="@color/text_muted" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:gap="4dp">

                            <TextView
                                android:id="@+id/tvLocationShared"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/post_sos_location_shared"
                                android:textSize="@dimen/text_caption"
                                android:fontFamily="@font/poppins_semibold"
                                android:textColor="@color/status_success" />

                            <ImageView
                                android:layout_width="14dp"
                                android:layout_height="14dp"
                                android:src="@drawable/ic_gps_chip"
                                android:contentDescription="@null"
                                android:layout_marginStart="@dimen/spacing_xs" />

                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- ===== RESPONDER STATUS CARD ===== -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardResponderStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_md"
                app:cardBackgroundColor="@color/card_dark"
                app:cardCornerRadius="@dimen/card_radius_md"
                app:cardElevation="0dp">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="@dimen/spacing_lg">

                    <!-- Left: responder info -->
                    <ImageView
                        android:id="@+id/ivResponderIcon"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/ic_responders_chip"
                        android:background="@drawable/bg_icon_circle_red"
                        android:padding="@dimen/spacing_sm"
                        android:contentDescription="@string/cd_responders_icon"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent" />

                    <TextView
                        android:id="@+id/tvResponderTitle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="@string/post_sos_responder_title"
                        android:textSize="@dimen/text_caption"
                        android:fontFamily="@font/poppins_semibold"
                        android:textColor="@color/white"
                        app:layout_constraintTop_toTopOf="@id/ivResponderIcon"
                        app:layout_constraintStart_toEndOf="@id/ivResponderIcon"
                        app:layout_constraintEnd_toStartOf="@id/tvResponderBadge"
                        android:layout_marginStart="@dimen/spacing_md" />

                    <TextView
                        android:id="@+id/tvResponderSub"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="@string/post_sos_responder_sub"
                        android:textSize="@dimen/text_micro"
                        android:fontFamily="@font/poppins_regular"
                        android:textColor="@color/text_muted"
                        app:layout_constraintTop_toBottomOf="@id/tvResponderTitle"
                        app:layout_constraintStart_toEndOf="@id/ivResponderIcon"
                        app:layout_constraintEnd_toStartOf="@id/tvResponderBadge"
                        android:layout_marginStart="@dimen/spacing_md"
                        android:layout_marginTop="@dimen/spacing_xxs" />

                    <!-- Status badge -->
                    <TextView
                        android:id="@+id/tvResponderBadge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/post_sos_responder_badge"
                        android:textSize="@dimen/text_micro"
                        android:fontFamily="@font/poppins_semibold"
                        android:textColor="@color/status_warning"
                        android:background="@drawable/bg_status_warning"
                        android:paddingStart="@dimen/spacing_sm"
                        android:paddingEnd="@dimen/spacing_sm"
                        android:paddingTop="@dimen/spacing_xxs"
                        android:paddingBottom="@dimen/spacing_xxs"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent" />

                </androidx.constraintlayout.widget.ConstraintLayout>

            </androidx.cardview.widget.CardView>

            <!-- ===== ETA CARD ===== -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardETA"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_md"
                app:cardBackgroundColor="@color/card_dark"
                app:cardCornerRadius="@dimen/card_radius_md"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="@dimen/spacing_lg">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_eta"
                        android:contentDescription="@string/cd_eta"
                        android:layout_marginEnd="@dimen/spacing_md" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/post_sos_eta_label"
                        android:textSize="@dimen/text_caption"
                        android:fontFamily="@font/poppins_regular"
                        android:textColor="@color/text_muted" />

                    <TextView
                        android:id="@+id/tvETA"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/post_sos_eta_value"
                        android:textSize="18sp"
                        android:fontFamily="@font/poppins_bold"
                        android:textColor="@color/white" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- ===== ACTION BUTTONS ===== -->

            <!-- Add more details button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAddDetails"
                android:layout_width="match_parent"
                android:layout_height="@dimen/btn_height_lg"
                android:text="@string/post_sos_btn_add_details"
                android:textSize="@dimen/text_button"
                android:fontFamily="@font/poppins_bold"
                android:textColor="@color/white"
                android:backgroundTint="@color/sos_core_red"
                app:cornerRadius="@dimen/btn_radius"
                app:icon="@drawable/ic_report"
                app:iconTint="@color/white"
                app:iconGravity="textStart"
                android:layout_marginTop="@dimen/spacing_xl" />

            <!-- Enter email for report button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnEnterEmail"
                android:layout_width="match_parent"
                android:layout_height="@dimen/btn_height_lg"
                android:text="@string/post_sos_btn_email_report"
                android:textSize="@dimen/text_button"
                android:fontFamily="@font/poppins_semibold"
                android:textColor="@color/white"
                android:backgroundTint="@color/card_mid"
                app:cornerRadius="@dimen/btn_radius"
                app:strokeColor="@color/rim_border"
                app:strokeWidth="1dp"
                app:icon="@drawable/ic_email"
                app:iconTint="@color/white"
                app:iconGravity="textStart"
                android:layout_marginTop="@dimen/spacing_sm" />

            <!-- Track live button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnTrackLive"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="@dimen/btn_height_lg"
                android:text="@string/post_sos_btn_track"
                android:textSize="@dimen/text_button"
                android:fontFamily="@font/poppins_medium"
                android:textColor="@color/text_muted"
                app:cornerRadius="@dimen/btn_radius"
                app:strokeColor="@color/rim_border"
                app:strokeWidth="1dp"
                app:icon="@drawable/ic_map_pin"
                app:iconTint="@color/text_muted"
                app:iconGravity="textStart"
                android:layout_marginTop="@dimen/spacing_sm" />

            <!-- Emergency call strip -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardEmergencyCall"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_lg"
                app:cardBackgroundColor="#1AE63946"
                app:cardCornerRadius="@dimen/card_radius_md"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="@dimen/spacing_md">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/post_sos_call_strip_text"
                        android:textSize="@dimen/text_caption"
                        android:fontFamily="@font/poppins_regular"
                        android:textColor="@color/text_light"
                        android:lineSpacingMultiplier="1.4" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnCallNow"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/post_sos_btn_call_now"
                        android:textSize="@dimen/text_micro"
                        android:fontFamily="@font/poppins_bold"
                        android:textColor="@color/white"
                        android:backgroundTint="@color/sos_core_red"
                        android:layout_marginStart="@dimen/spacing_md"
                        app:cornerRadius="@dimen/btn_radius" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>