<?xml version="1.0" encoding="utf-8"?>
<!-- RapidGuard | Reusable incident history card -->
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/spacing_md"
    android:clickable="true"
    android:focusable="true"
    app:cardBackgroundColor="@color/card_dark"
    app:cardCornerRadius="@dimen/card_radius_md"
    app:cardElevation="0dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="@dimen/spacing_lg">

        <!-- Left: incident type icon circle -->
        <ImageView
            android:id="@+id/ivIncidentIcon"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_incident_medical"
            android:background="@drawable/bg_icon_circle_red"
            android:padding="@dimen/spacing_sm"
            android:contentDescription="@string/cd_incident_type"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <!-- Middle: type + datetime -->
        <TextView
            android:id="@+id/tvIncidentType"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Medical Emergency"
            android:textSize="@dimen/text_caption"
            android:fontFamily="@font/poppins_semibold"
            android:textColor="@color/white"
            app:layout_constraintTop_toTopOf="@id/ivIncidentIcon"
            app:layout_constraintStart_toEndOf="@id/ivIncidentIcon"
            app:layout_constraintEnd_toStartOf="@id/tvStatusBadge"
            android:layout_marginStart="@dimen/spacing_md" />

        <TextView
            android:id="@+id/tvIncidentDateTime"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Today, 07:14 AM"
            android:textSize="@dimen/text_micro"
            android:fontFamily="@font/poppins_regular"
            android:textColor="@color/text_muted"
            app:layout_constraintTop_toBottomOf="@id/tvIncidentType"
            app:layout_constraintStart_toEndOf="@id/ivIncidentIcon"
            app:layout_constraintEnd_toStartOf="@id/tvStatusBadge"
            android:layout_marginStart="@dimen/spacing_md"
            android:layout_marginTop="@dimen/spacing_xxs" />

        <TextView
            android:id="@+id/tvIncidentLocation"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Durban CBD"
            android:textSize="@dimen/text_micro"
            android:fontFamily="@font/poppins_regular"
            android:textColor="@color/text_muted"
            app:layout_constraintTop_toBottomOf="@id/tvIncidentDateTime"
            app:layout_constraintStart_toEndOf="@id/ivIncidentIcon"
            app:layout_constraintEnd_toStartOf="@id/tvStatusBadge"
            android:layout_marginStart="@dimen/spacing_md"
            android:layout_marginTop="@dimen/spacing_xxs" />

        <!-- Right: status badge + risk chip -->
        <TextView
            android:id="@+id/tvStatusBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Resolved"
            android:textSize="@dimen/text_micro"
            android:fontFamily="@font/poppins_semibold"
            android:textColor="@color/status_success"
            android:background="@drawable/bg_status_success"
            android:paddingStart="@dimen/spacing_sm"
            android:paddingEnd="@dimen/spacing_sm"
            android:paddingTop="@dimen/spacing_xxs"
            android:paddingBottom="@dimen/spacing_xxs"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tvRiskChip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="High"
            android:textSize="@dimen/text_micro"
            android:fontFamily="@font/poppins_medium"
            android:textColor="@color/status_danger"
            android:background="@drawable/bg_status_danger"
            android:paddingStart="@dimen/spacing_sm"
            android:paddingEnd="@dimen/spacing_sm"
            android:paddingTop="@dimen/spacing_xxs"
            android:paddingBottom="@dimen/spacing_xxs"
            app:layout_constraintTop_toBottomOf="@id/tvStatusBadge"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="@dimen/spacing_xs" />

        <!-- Bottom: chevron arrow -->
        <ImageView
            android:id="@+id/ivChevron"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:src="@drawable/ic_chevron_right"
            android:contentDescription="@null"
            android:alpha="0.4"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.cardview.widget.CardView>