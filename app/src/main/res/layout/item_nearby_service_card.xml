<?xml version="1.0" encoding="utf-8"?>
<!-- RapidGuard | Reusable nearby service card -->
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/spacing_md"
    android:clickable="true"
    android:focusable="true"
    app:cardBackgroundColor="@color/card_dark"
    app:cardCornerRadius="@dimen/card_radius_md"
    app:cardElevation="0dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="@dimen/spacing_lg">

        <!-- Service icon -->
        <ImageView
            android:id="@+id/ivServiceIcon"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_nav_map"
            android:background="@drawable/bg_icon_circle_red"
            android:padding="@dimen/spacing_sm"
            android:contentDescription="@string/cd_service_icon"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <!-- Service info -->
        <TextView
            android:id="@+id/tvServiceName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Service Name"
            android:textSize="@dimen/text_caption"
            android:fontFamily="@font/poppins_semibold"
            android:textColor="@color/white"
            app:layout_constraintTop_toTopOf="@id/ivServiceIcon"
            app:layout_constraintStart_toEndOf="@id/ivServiceIcon"
            app:layout_constraintEnd_toStartOf="@id/tvDistance"
            android:layout_marginStart="@dimen/spacing_md" />

        <TextView
            android:id="@+id/tvServiceAddress"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Address"
            android:textSize="@dimen/text_micro"
            android:fontFamily="@font/poppins_regular"
            android:textColor="@color/text_muted"
            app:layout_constraintTop_toBottomOf="@id/tvServiceName"
            app:layout_constraintStart_toEndOf="@id/ivServiceIcon"
            app:layout_constraintEnd_toStartOf="@id/tvDistance"
            android:layout_marginStart="@dimen/spacing_md"
            android:layout_marginTop="@dimen/spacing_xxs" />

        <TextView
            android:id="@+id/tvServiceHours"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Open 24 hours"
            android:textSize="@dimen/text_micro"
            android:fontFamily="@font/poppins_regular"
            android:textColor="@color/status_success"
            app:layout_constraintTop_toBottomOf="@id/tvServiceAddress"
            app:layout_constraintStart_toEndOf="@id/ivServiceIcon"
            app:layout_constraintEnd_toStartOf="@id/tvDistance"
            android:layout_marginStart="@dimen/spacing_md"
            android:layout_marginTop="@dimen/spacing_xxs" />

        <!-- Distance badge -->
        <TextView
            android:id="@+id/tvDistance"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="1.2 km"
            android:textSize="@dimen/text_micro"
            android:fontFamily="@font/poppins_bold"
            android:textColor="@color/white"
            android:background="@drawable/bg_badge_dark"
            android:paddingStart="@dimen/spacing_sm"
            android:paddingEnd="@dimen/spacing_sm"
            android:paddingTop="@dimen/spacing_xxs"
            android:paddingBottom="@dimen/spacing_xxs"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Divider -->
        <View
            android:id="@+id/divider"
            android:layout_width="0dp"
            android:layout_height="0.5dp"
            android:background="@color/rim_border"
            app:layout_constraintTop_toBottomOf="@id/ivServiceIcon"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="@dimen/spacing_md" />

        <!-- Action buttons row -->
        <LinearLayout
            android:id="@+id/actionRow"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="@dimen/spacing_md"
            app:layout_constraintTop_toBottomOf="@id/divider"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- Call button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCall"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:layout_marginEnd="@dimen/spacing_xs"
                android:text="@string/nearby_btn_call"
                android:textSize="@dimen/text_micro"
                android:fontFamily="@font/poppins_semibold"
                android:textColor="@color/white"
                android:backgroundTint="@color/sos_core_red"
                app:cornerRadius="@dimen/card_radius_sm"
                app:icon="@drawable/ic_phone"
                app:iconTint="@color/white"
                app:iconSize="14dp"
                app:iconGravity="textStart" />

            <!-- Directions button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDirections"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:layout_marginStart="@dimen/spacing_xs"
                android:text="@string/nearby_btn_directions"
                android:textSize="@dimen/text_micro"
                android:fontFamily="@font/poppins_medium"
                android:textColor="@color/text_muted"
                app:cornerRadius="@dimen/card_radius_sm"
                app:strokeColor="@color/rim_border"
                app:strokeWidth="1dp"
                app:icon="@drawable/ic_map_pin"
                app:iconTint="@color/text_muted"
                app:iconSize="14dp"
                app:iconGravity="textStart" />

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.cardview.widget.CardView>