<?xml version="1.0" encoding="utf-8"?>
<!-- RapidGuard | Screen 10: Live Incident Tracking Screen | Group 41 -->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/trackingRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient_radial"
    tools:context=".LiveIncidentTrackingActivity">

    <!-- Grid overlay -->
    <View
        android:id="@+id/gridOverlay"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@drawable/bg_grid_overlay"
        android:alpha="0.04"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Scrollable content -->
    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:scrollbars="none"
        android:clipToPadding="false"
        android:paddingBottom="@dimen/bottom_nav_height"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/bottomNav"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ===== MAP PLACEHOLDER ===== -->
            <FrameLayout
                android:id="@+id/mapContainer"
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:background="@color/card_dark">

                <!-- SupportMapFragment goes here at runtime -->
                <fragment
                    android:id="@+id/mapFragment"
                    android:name="com.google.android.gms.maps.SupportMapFragment"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    tools:layout="@layout/fragment_map_placeholder" />

                <!-- Map loading placeholder (shown before map loads) -->
                <LinearLayout
                    android:id="@+id/mapPlaceholder"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@color/card_dark"
                    android:visibility="visible">

                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/ic_map_pin"
                        android:contentDescription="@string/cd_map_placeholder"
                        android:alpha="0.4" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/tracking_map_loading"
                        android:textSize="@dimen/text_caption"
                        android:fontFamily="@font/poppins_regular"
                        android:textColor="@color/text_muted"
                        android:layout_marginTop="@dimen/spacing_sm" />

                </LinearLayout>

                <!-- Live badge overlay on map -->
                <LinearLayout
                    android:id="@+id/liveBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_card_dark"
                    android:padding="@dimen/spacing_sm"
                    android:layout_gravity="top|start"
                    android:layout_margin="@dimen/spacing_md">

                    <View
                        android:id="@+id/liveDot"
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:background="@drawable/bg_dot_red"
                        android:layout_marginEnd="@dimen/spacing_xs" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/tracking_live_badge"
                        android:textSize="@dimen/text_micro"
                        android:fontFamily="@font/poppins_semibold"
                        android:textColor="@color/sos_core_red"
                        android:letterSpacing="0.08"
                        android:textAllCaps="true" />

                </LinearLayout>

                <!-- Incident ref overlay on map -->
                <TextView
                    android:id="@+id/tvMapRef"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/post_sos_ref_number"
                    android:textSize="@dimen/text_micro"
                    android:fontFamily="@font/poppins_semibold"
                    android:textColor="@color/text_muted"
                    android:background="@drawable/bg_badge_dark"
                    android:paddingStart="@dimen/spacing_sm"
                    android:paddingEnd="@dimen/spacing_sm"
                    android:paddingTop="@dimen/spacing_xxs"
                    android:paddingBottom="@dimen/spacing_xxs"
                    android:layout_gravity="top|end"
                    android:layout_margin="@dimen/spacing_md" />

                <!-- Back button over map -->
                <ImageButton
                    android:id="@+id/btnBack"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/ic_arrow_back"
                    android:background="@drawable/bg_card_dark"
                    android:contentDescription="@string/cd_back"
                    android:padding="@dimen/spacing_sm"
                    android:layout_gravity="bottom|start"
                    android:layout_margin="@dimen/spacing_md" />

            </FrameLayout>

            <!-- ===== CARD AREA (below map) ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="@dimen/spacing_lg"
                android:paddingEnd="@dimen/spacing_lg"
                android:paddingBottom="@dimen/spacing_xl">

                <!-- ===== STATUS TRACKER ===== -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/tracking_status_label"
                    android:textSize="@dimen/text_caption"
                    android:fontFamily="@font/poppins_semibold"
                    android:textColor="@color/text_light"
                    android:layout_marginTop="@dimen/spacing_lg" />

                <!-- 4-step status tracker -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardStatusTracker"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_sm"
                    app:cardBackgroundColor="@color/card_dark"
                    app:cardCornerRadius="@dimen/card_radius_md"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="@dimen/spacing_lg">

                        <!-- Step row: Reported -->
                        <include layout="@layout/item_tracking_step"
                            android:id="@+id/stepReported" />

                        <!-- Connector line -->
                        <View
                            android:layout_width="2dp"
                            android:layout_height="20dp"
                            android:layout_marginStart="17dp"
                            android:background="@color/status_success" />

                        <!-- Step row: Acknowledged -->
                        <include layout="@layout/item_tracking_step"
                            android:id="@+id/stepAcknowledged" />

                        <View
                            android:layout_width="2dp"
                            android:layout_height="20dp"
                            android:layout_marginStart="17dp"
                            android:background="@color/status_warning" />

                        <!-- Step row: In Progress (ACTIVE) -->
                        <include layout="@layout/item_tracking_step"
                            android:id="@+id/stepInProgress" />

                        <View
                            android:layout_width="2dp"
                            android:layout_height="20dp"
                            android:layout_marginStart="17dp"
                            android:background="@color/rim_border" />

                        <!-- Step row: Resolved -->
                        <include layout="@layout/item_tracking_step"
                            android:id="@+id/stepResolved" />

                    </LinearLayout>

                </androidx.cardview.widget.CardView>

                <!-- ===== RESPONDER ASSIGNED CARD ===== -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/tracking_responder_label"
                    android:textSize="@dimen/text_caption"
                    android:fontFamily="@font/poppins_semibold"
                    android:textColor="@color/text_light"
                    android:layout_marginTop="@dimen/spacing_xl" />

                <androidx.cardview.widget.CardView
                    android:id="@+id/cardResponder"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_sm"
                    app:cardBackgroundColor="@color/card_dark"
                    app:cardCornerRadius="@dimen/card_radius_md"
                    app:cardElevation="0dp">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="@dimen/spacing_lg">

                        <!-- Responder avatar -->
                        <androidx.cardview.widget.CardView
                            android:id="@+id/cvResponderAvatar"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            app:cardBackgroundColor="@color/card_inner_glow"
                            app:cardCornerRadius="24dp"
                            app:cardElevation="0dp"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintStart_toStartOf="parent">

                            <TextView
                                android:id="@+id/tvResponderInitial"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:text="@string/tracking_responder_initial"
                                android:textSize="18sp"
                                android:fontFamily="@font/poppins_bold"
                                android:textColor="@color/white"
                                android:gravity="center" />

                        </androidx.cardview.widget.CardView>

                        <!-- Responder info -->
                        <TextView
                            android:id="@+id/tvResponderName"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:text="@string/tracking_responder_name"
                            android:textSize="@dimen/text_button"
                            android:fontFamily="@font/poppins_semibold"
                            android:textColor="@color/white"
                            app:layout_constraintTop_toTopOf="@id/cvResponderAvatar"
                            app:layout_constraintStart_toEndOf="@id/cvResponderAvatar"
                            app:layout_constraintEnd_toStartOf="@id/tvResponderStatusBadge"
                            android:layout_marginStart="@dimen/spacing_md" />

                        <TextView
                            android:id="@+id/tvResponderRole"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:text="@string/tracking_responder_role"
                            android:textSize="@dimen/text_micro"
                            android:fontFamily="@font/poppins_regular"
                            android:textColor="@color/text_muted"
                            app:layout_constraintTop_toBottomOf="@id/tvResponderName"
                            app:layout_constraintStart_toEndOf="@id/cvResponderAvatar"
                            app:layout_constraintEnd_toStartOf="@id/tvResponderStatusBadge"
                            android:layout_marginStart="@dimen/spacing_md"
                            android:layout_marginTop="@dimen/spacing_xxs" />

                        <TextView
                            android:id="@+id/tvResponderUnit"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:text="@string/tracking_responder_unit"
                            android:textSize="@dimen/text_micro"
                            android:fontFamily="@font/poppins_regular"
                            android:textColor="@color/text_muted"
                            app:layout_constraintTop_toBottomOf="@id/tvResponderRole"
                            app:layout_constraintStart_toEndOf="@id/cvResponderAvatar"
                            app:layout_constraintEnd_toStartOf="@id/tvResponderStatusBadge"
                            android:layout_marginStart="@dimen/spacing_md"
                            android:layout_marginTop="@dimen/spacing_xxs" />

                        <!-- Status badge -->
                        <TextView
                            android:id="@+id/tvResponderStatusBadge"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/tracking_responder_badge"
                            android:textSize="@dimen/text_micro"
                            android:fontFamily="@font/poppins_semibold"
                            android:textColor="@color/status_warning"
                            android:background="@drawable/bg_status_warning"
                            android:paddingStart="@dimen/spacing_sm"
                            android:paddingEnd="@dimen/spacing_sm"
                            android:paddingTop="@dimen/spacing_xxs"
                            android:paddingBottom="@dimen/spacing_xxs"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent" />

                    </androidx.constraintlayout.widget.ConstraintLayout>

                </androidx.cardview.widget.CardView>

                <!-- ===== ETA CARD ===== -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardETA"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_md"
                    app:cardBackgroundColor="@color/card_dark"
                    app:cardCornerRadius="@dimen/card_radius_md"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="@dimen/spacing_lg"
                        android:weightSum="3">

                        <!-- ETA -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/tracking_eta_label"
                                android:textSize="@dimen/text_micro"
                                android:fontFamily="@font/poppins_regular"
                                android:textColor="@color/text_muted" />

                            <TextView
                                android:id="@+id/tvETA"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/tracking_eta_value"
                                android:textSize="20sp"
                                android:fontFamily="@font/poppins_bold"
                                android:textColor="@color/white"
                                android:layout_marginTop="@dimen/spacing_xxs" />

                        </LinearLayout>

                        <!-- Vertical separator -->
                        <View
                            android:layout_width="0.5dp"
                            android:layout_height="40dp"
                            android:layout_weight="0"
                            android:background="@color/rim_border" />

                        <!-- Distance -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/tracking_distance_label"
                                android:textSize="@dimen/text_micro"
                                android:fontFamily="@font/poppins_regular"
                                android:textColor="@color/text_muted" />

                            <TextView
                                android:id="@+id/tvDistance"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/tracking_distance_value"
                                android:textSize="20sp"
                                android:fontFamily="@font/poppins_bold"
                                android:textColor="@color/white"
                                android:layout_marginTop="@dimen/spacing_xxs" />

                        </LinearLayout>

                        <!-- Vertical separator -->
                        <View
                            android:layout_width="0.5dp"
                            android:layout_height="40dp"
                            android:layout_weight="0"
                            android:background="@color/rim_border" />

                        <!-- Speed -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/tracking_speed_label"
                                android:textSize="@dimen/text_micro"
                                android:fontFamily="@font/poppins_regular"
                                android:textColor="@color/text_muted" />

                            <TextView
                                android:id="@+id/tvSpeed"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/tracking_speed_value"
                                android:textSize="20sp"
                                android:fontFamily="@font/poppins_bold"
                                android:textColor="@color/status_success"
                                android:layout_marginTop="@dimen/spacing_xxs" />

                        </LinearLayout>

                    </LinearLayout>

                </androidx.cardview.widget.CardView>

                <!-- ===== CONTACT RESPONDER BUTTON ===== -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnContactResponder"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/btn_height_lg"
                    android:text="@string/tracking_btn_contact"
                    android:textSize="@dimen/text_button"
                    android:fontFamily="@font/poppins_bold"
                    android:textColor="@color/white"
                    android:backgroundTint="@color/sos_core_red"
                    app:cornerRadius="@dimen/btn_radius"
                    app:icon="@drawable/ic_phone"
                    app:iconTint="@color/white"
                    app:iconGravity="textStart"
                    android:layout_marginTop="@dimen/spacing_xl" />

                <!-- Share location button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnShareLocation"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/btn_height_lg"
                    android:text="@string/tracking_btn_share_location"
                    android:textSize="@dimen/text_button"
                    android:fontFamily="@font/poppins_medium"
                    android:textColor="@color/text_muted"
                    app:cornerRadius="@dimen/btn_radius"
                    app:strokeColor="@color/rim_border"
                    app:strokeWidth="1dp"
                    app:icon="@drawable/ic_map_pin"
                    app:iconTint="@color/text_muted"
                    app:iconGravity="textStart"
                    android:layout_marginTop="@dimen/spacing_sm" />

                <!-- Add details button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnAddDetails"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/btn_height_lg"
                    android:text="@string/tracking_btn_add_details"
                    android:textSize="@dimen/text_button"
                    android:fontFamily="@font/poppins_medium"
                    android:textColor="@color/text_muted"
                    app:cornerRadius="@dimen/btn_radius"
                    app:strokeColor="@color/rim_border"
                    app:strokeWidth="1dp"
                    app:icon="@drawable/ic_report"
                    app:iconTint="@color/text_muted"
                    app:iconGravity="textStart"
                    android:layout_marginTop="@dimen/spacing_sm" />

            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <!-- Bottom navigation -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="0dp"
        android:layout_height="@dimen/bottom_nav_height"
        android:background="@drawable/bg_nav_background"
        app:menu="@menu/bottom_nav_menu"
        app:itemIconTint="@color/nav_item_color"
        app:itemTextColor="@color/nav_item_color"
        app:itemActiveIndicatorColor="@color/nav_active_indicator"
        app:labelVisibilityMode="labeled"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>