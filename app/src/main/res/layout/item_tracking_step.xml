<?xml version="1.0" encoding="utf-8"?>
<!-- Reusable step row for the incident status tracker -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical">

    <!-- Step circle icon -->
    <ImageView
        android:id="@+id/ivStepIcon"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:src="@drawable/ic_check_circle"
        android:contentDescription="@null"
        android:padding="6dp" />

    <!-- Step info -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="@dimen/spacing_md">

        <TextView
            android:id="@+id/tvStepTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Step title"
            android:textSize="@dimen/text_caption"
            android:fontFamily="@font/poppins_semibold"
            android:textColor="@color/white" />

        <TextView
            android:id="@+id/tvStepSub"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Step subtitle"
            android:textSize="@dimen/text_micro"
            android:fontFamily="@font/poppins_regular"
            android:textColor="@color/text_muted"
            android:layout_marginTop="@dimen/spacing_xxs" />

    </LinearLayout>

    <!-- Step timestamp / badge -->
    <TextView
        android:id="@+id/tvStepTime"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="09:41"
        android:textSize="@dimen/text_micro"
        android:fontFamily="@font/poppins_medium"
        android:textColor="@color/text_muted" />

</LinearLayout>