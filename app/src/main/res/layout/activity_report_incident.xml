<?xml version="1.0" encoding="utf-8"?>
<!-- RapidGuard | Screen 9: Emergency Reporting Screen | Group 41 -->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/reportRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient_radial"
    tools:context=".ReportIncidentActivity">

    <!-- Grid overlay -->
    <View
        android:id="@+id/gridOverlay"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@drawable/bg_grid_overlay"
        android:alpha="0.04"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Scrollable form -->
    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:scrollbars="none"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/spacing_lg"
            android:paddingEnd="@dimen/spacing_lg"
            android:paddingBottom="@dimen/spacing_xxl">

            <!-- ===== TOP BAR ===== -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="@dimen/spacing_xxl">

                <ImageButton
                    android:id="@+id/btnBack"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_arrow_back"
                    android:background="@drawable/bg_card_dark"
                    android:contentDescription="@string/cd_back"
                    android:padding="@dimen/spacing_sm"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent" />

                <TextView
                    android:id="@+id/tvScreenLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/report_label"
                    android:textSize="@dimen/text_micro"
                    android:fontFamily="@font/poppins_medium"
                    android:textColor="@color/sos_core_red"
                    android:letterSpacing="0.12"
                    android:textAllCaps="true"
                    app:layout_constraintTop_toTopOf="@id/btnBack"
                    app:layout_constraintBottom_toBottomOf="@id/btnBack"
                    app:layout_constraintStart_toEndOf="@id/btnBack"
                    android:layout_marginStart="@dimen/spacing_md" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Heading -->
            <TextView
                android:id="@+id/tvHeading"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/report_heading"
                android:textSize="@dimen/text_heading"
                android:fontFamily="@font/poppins_bold"
                android:textColor="@color/white"
                android:lineSpacingMultiplier="1.2"
                android:layout_marginTop="@dimen/spacing_lg" />

            <TextView
                android:id="@+id/tvSubheading"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/report_subheading"
                android:textSize="@dimen/text_body"
                android:fontFamily="@font/poppins_regular"
                android:textColor="@color/text_muted"
                android:layout_marginTop="@dimen/spacing_xs" />

            <!-- Red divider -->
            <View
                android:layout_width="@dimen/divider_width"
                android:layout_height="@dimen/divider_height"
                android:background="@drawable/bg_red_divider"
                android:layout_marginTop="@dimen/spacing_lg" />

            <!-- ===== SECTION: EMERGENCY TYPE ===== -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/report_type_label"
                android:textSize="@dimen/text_caption"
                android:fontFamily="@font/poppins_semibold"
                android:textColor="@color/text_light"
                android:layout_marginTop="@dimen/spacing_xl" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/report_type_hint"
                android:textSize="@dimen/text_micro"
                android:fontFamily="@font/poppins_regular"
                android:textColor="@color/text_muted"
                android:layout_marginTop="@dimen/spacing_xxs"
                android:layout_marginBottom="@dimen/spacing_md" />

            <!-- Emergency type chip group -->
            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chipGroupType"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:singleSelection="true"
                app:chipSpacingHorizontal="@dimen/spacing_xs"
                app:chipSpacingVertical="@dimen/spacing_xs">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipMedical"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/chip_type_medical"
                    android:textColor="@color/white"
                    android:fontFamily="@font/poppins_medium"
                    app:chipIcon="@drawable/ic_incident_medical"
                    app:chipIconTint="@color/white"
                    app:chipBackgroundColor="@color/chip_selector"
                    app:chipStrokeColor="@color/rim_border"
                    app:chipStrokeWidth="1dp" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipFire"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/chip_type_fire"
                    android:textColor="@color/white"
                    android:fontFamily="@font/poppins_medium"
                    app:chipIcon="@drawable/ic_fire"
                    app:chipIconTint="@color/white"
                    app:chipBackgroundColor="@color/chip_selector"
                    app:chipStrokeColor="@color/rim_border"
                    app:chipStrokeWidth="1dp" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipCrime"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/chip_type_crime"
                    android:textColor="@color/white"
                    android:fontFamily="@font/poppins_medium"
                    app:chipIcon="@drawable/ic_crime"
                    app:chipIconTint="@color/white"
                    app:chipBackgroundColor="@color/chip_selector"
                    app:chipStrokeColor="@color/rim_border"
                    app:chipStrokeWidth="1dp" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipAccident"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/chip_type_accident"
                    android:textColor="@color/white"
                    android:fontFamily="@font/poppins_medium"
                    app:chipIcon="@drawable/ic_accident"
                    app:chipIconTint="@color/white"
                    app:chipBackgroundColor="@color/chip_selector"
                    app:chipStrokeColor="@color/rim_border"
                    app:chipStrokeWidth="1dp" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipUnknown"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/chip_type_unknown"
                    android:textColor="@color/white"
                    android:fontFamily="@font/poppins_medium"
                    app:chipBackgroundColor="@color/chip_selector"
                    app:chipStrokeColor="@color/rim_border"
                    app:chipStrokeWidth="1dp" />

            </com.google.android.material.chip.ChipGroup>

            <!-- ===== SECTION: DESCRIPTION ===== -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/report_description_label"
                android:textSize="@dimen/text_caption"
                android:fontFamily="@font/poppins_semibold"
                android:textColor="@color/text_light"
                android:layout_marginTop="@dimen/spacing_xl" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilDescription"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/report_description_hint"
                app:boxBackgroundColor="@color/card_dark"
                app:boxStrokeColor="@color/rim_border"
                app:boxStrokeWidth="1dp"
                app:boxCornerRadiusTopStart="@dimen/card_radius_sm"
                app:boxCornerRadiusTopEnd="@dimen/card_radius_sm"
                app:boxCornerRadiusBottomStart="@dimen/card_radius_sm"
                app:boxCornerRadiusBottomEnd="@dimen/card_radius_sm"
                app:hintTextColor="@color/text_muted"
                app:counterEnabled="true"
                app:counterMaxLength="300"
                app:counterTextColor="@color/text_muted"
                android:layout_marginTop="@dimen/spacing_sm">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etDescription"
                    android:layout_width="match_parent"
                    android:layout_height="120dp"
                    android:inputType="textMultiLine|textCapSentences"
                    android:gravity="top|start"
                    android:textColor="@color/white"
                    android:textSize="@dimen/text_body"
                    android:fontFamily="@font/poppins_regular"
                    android:maxLength="300"
                    android:imeOptions="actionDone" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- ===== SECTION: MEDIA ATTACHMENTS ===== -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/report_media_label"
                android:textSize="@dimen/text_caption"
                android:fontFamily="@font/poppins_semibold"
                android:textColor="@color/text_light"
                android:layout_marginTop="@dimen/spacing_xl" />

            <LinearLayout
                android:id="@+id/mediaRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="@dimen/spacing_md"
                android:weightSum="2">

                <!-- Voice note button -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardVoiceNote"
                    android:layout_width="0dp"
                    android:layout_height="72dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="@dimen/spacing_xs"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardBackgroundColor="@color/card_dark"
                    app:cardCornerRadius="@dimen/card_radius_md"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="horizontal"
                        android:gravity="center"
                        android:padding="@dimen/spacing_md">

                        <ImageView
                            android:id="@+id/ivVoiceIcon"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_microphone"
                            android:contentDescription="@string/cd_voice_note"
                            android:layout_marginEnd="@dimen/spacing_sm" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/report_voice_title"
                                android:textSize="@dimen/text_caption"
                                android:fontFamily="@font/poppins_semibold"
                                android:textColor="@color/white" />

                            <TextView
                                android:id="@+id/tvVoiceSub"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/report_voice_sub"
                                android:textSize="@dimen/text_micro"
                                android:fontFamily="@font/poppins_regular"
                                android:textColor="@color/text_muted" />

                        </LinearLayout>

                    </LinearLayout>

                </androidx.cardview.widget.CardView>

                <!-- Upload image button -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardUploadImage"
                    android:layout_width="0dp"
                    android:layout_height="72dp"
                    android:layout_weight="1"
                    android:layout_marginStart="@dimen/spacing_xs"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardBackgroundColor="@color/card_dark"
                    app:cardCornerRadius="@dimen/card_radius_md"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="horizontal"
                        android:gravity="center"
                        android:padding="@dimen/spacing_md">

                        <ImageView
                            android:id="@+id/ivUploadIcon"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_camera"
                            android:contentDescription="@string/cd_upload_image"
                            android:layout_marginEnd="@dimen/spacing_sm" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/report_image_title"
                                android:textSize="@dimen/text_caption"
                                android:fontFamily="@font/poppins_semibold"
                                android:textColor="@color/white" />

                            <TextView
                                android:id="@+id/tvImageSub"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/report_image_sub"
                                android:textSize="@dimen/text_micro"
                                android:fontFamily="@font/poppins_regular"
                                android:textColor="@color/text_muted" />

                        </LinearLayout>

                    </LinearLayout>

                </androidx.cardview.widget.CardView>

            </LinearLayout>

            <!-- Image preview strip (hidden until image picked) -->
            <HorizontalScrollView
                android:id="@+id/imagePreviewScroll"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:visibility="gone"
                android:layout_marginTop="@dimen/spacing_sm">

                <LinearLayout
                    android:id="@+id/imagePreviewContainer"
                    android:layout_width="wrap_content"
                    android:layout_height="72dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical" />

            </HorizontalScrollView>

            <!-- Voice recording indicator (hidden until recording) -->
            <LinearLayout
                android:id="@+id/voiceRecordingBar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_card_dark"
                android:padding="@dimen/spacing_md"
                android:layout_marginTop="@dimen/spacing_sm"
                android:visibility="gone">

                <View
                    android:id="@+id/recDot"
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:background="@drawable/bg_dot_red"
                    android:layout_marginEnd="@dimen/spacing_sm" />

                <TextView
                    android:id="@+id/tvRecordingTime"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/report_recording"
                    android:textSize="@dimen/text_caption"
                    android:fontFamily="@font/poppins_medium"
                    android:textColor="@color/sos_core_red" />

                <ImageButton
                    android:id="@+id/btnStopRecording"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_stop"
                    android:background="@drawable/bg_dot_red"
                    android:contentDescription="@string/cd_stop_recording"
                    android:padding="@dimen/spacing_xs" />

            </LinearLayout>

            <!-- ===== SECTION: LOCATION CARD ===== -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/report_location_label"
                android:textSize="@dimen/text_caption"
                android:fontFamily="@font/poppins_semibold"
                android:textColor="@color/text_light"
                android:layout_marginTop="@dimen/spacing_xl" />

            <androidx.cardview.widget.CardView
                android:id="@+id/cardLocation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_sm"
                app:cardBackgroundColor="@color/card_dark"
                app:cardCornerRadius="@dimen/card_radius_md"
                app:cardElevation="0dp">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="@dimen/spacing_md">

                    <ImageView
                        android:id="@+id/ivLocationPin"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_map_pin"
                        android:contentDescription="@string/cd_gps_icon"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent" />

                    <TextView
                        android:id="@+id/tvLocationAddress"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="@string/report_location_address"
                        android:textSize="@dimen/text_caption"
                        android:fontFamily="@font/poppins_medium"
                        android:textColor="@color/white"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toEndOf="@id/ivLocationPin"
                        app:layout_constraintEnd_toStartOf="@id/btnRefreshLocation"
                        android:layout_marginStart="@dimen/spacing_md" />

                    <TextView
                        android:id="@+id/tvLocationCoords"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="@string/report_location_coords"
                        android:textSize="@dimen/text_micro"
                        android:fontFamily="@font/poppins_regular"
                        android:textColor="@color/text_muted"
                        app:layout_constraintTop_toBottomOf="@id/tvLocationAddress"
                        app:layout_constraintStart_toEndOf="@id/ivLocationPin"
                        app:layout_constraintEnd_toStartOf="@id/btnRefreshLocation"
                        android:layout_marginStart="@dimen/spacing_md"
                        android:layout_marginTop="@dimen/spacing_xxs" />

                    <!-- Refresh location button -->
                    <ImageButton
                        android:id="@+id/btnRefreshLocation"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/ic_refresh"
                        android:background="@drawable/bg_card_dark"
                        android:contentDescription="@string/cd_refresh_location"
                        android:padding="@dimen/spacing_xs"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent" />

                </androidx.constraintlayout.widget.ConstraintLayout>

            </androidx.cardview.widget.CardView>

            <!-- ===== SECTION: SEVERITY ===== -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/report_severity_label"
                android:textSize="@dimen/text_caption"
                android:fontFamily="@font/poppins_semibold"
                android:textColor="@color/text_light"
                android:layout_marginTop="@dimen/spacing_xl" />

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chipGroupSeverity"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:singleSelection="true"
                android:layout_marginTop="@dimen/spacing_sm">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipLow"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/severity_low"
                    android:textColor="@color/white"
                    android:fontFamily="@font/poppins_medium"
                    app:chipBackgroundColor="@color/chip_selector"
                    app:chipStrokeColor="@color/status_success"
                    app:chipStrokeWidth="1dp" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipMedium"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/severity_medium"
                    android:textColor="@color/white"
                    android:fontFamily="@font/poppins_medium"
                    app:chipBackgroundColor="@color/chip_selector"
                    app:chipStrokeColor="@color/status_warning"
                    app:chipStrokeWidth="1dp" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipHigh"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/severity_high"
                    android:textColor="@color/white"
                    android:fontFamily="@font/poppins_medium"
                    app:chipBackgroundColor="@color/chip_selector"
                    app:chipStrokeColor="@color/status_danger"
                    app:chipStrokeWidth="1dp" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipCritical"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/severity_critical"
                    android:textColor="@color/white"
                    android:fontFamily="@font/poppins_medium"
                    app:chipBackgroundColor="@color/chip_selector"
                    app:chipStrokeColor="@color/sos_hot_red"
                    app:chipStrokeWidth="1dp" />

            </com.google.android.material.chip.ChipGroup>

            <!-- ===== SUBMIT BUTTON ===== -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSubmitDetails"
                android:layout_width="match_parent"
                android:layout_height="@dimen/btn_height_lg"
                android:text="@string/report_btn_submit"
                android:textSize="@dimen/text_button"
                android:fontFamily="@font/poppins_bold"
                android:textColor="@color/white"
                android:backgroundTint="@color/sos_core_red"
                app:cornerRadius="@dimen/btn_radius"
                app:icon="@drawable/ic_send"
                app:iconTint="@color/white"
                app:iconGravity="textStart"
                android:layout_marginTop="@dimen/spacing_xxl" />

            <!-- Save as draft link -->
            <TextView
                android:id="@+id/tvSaveDraft"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/report_save_draft"
                android:textSize="@dimen/text_caption"
                android:fontFamily="@font/poppins_medium"
                android:textColor="@color/text_muted"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="@dimen/spacing_md"
                android:paddingTop="@dimen/spacing_sm"
                android:paddingBottom="@dimen/spacing_sm"
                android:clickable="true"
                android:focusable="true" />

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>