<?xml version="1.0" encoding="utf-8"?>
<!-- RapidGuard | Screen 8: Post-SOS Email Capture / Account Completion | Group 41 -->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/emailCaptureRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient_radial"
    tools:context=".PostSosEmailCaptureActivity">

    <!-- Grid overlay -->
    <View
        android:id="@+id/gridOverlay"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@drawable/bg_grid_overlay"
        android:alpha="0.04"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:scrollbars="none"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/spacing_lg"
            android:paddingEnd="@dimen/spacing_lg"
            android:paddingBottom="@dimen/spacing_xxl">

            <!-- ===== TOP BAR ===== -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="@dimen/spacing_xxl">

                <!-- Back button -->
                <ImageButton
                    android:id="@+id/btnBack"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_arrow_back"
                    android:background="@drawable/bg_card_dark"
                    android:contentDescription="@string/cd_back"
                    android:padding="@dimen/spacing_sm"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent" />

                <!-- Step indicator top-right -->
                <TextView
                    android:id="@+id/tvStepBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/email_capture_step"
                    android:textSize="@dimen/text_micro"
                    android:fontFamily="@font/poppins_medium"
                    android:textColor="@color/text_muted"
                    android:background="@drawable/bg_badge_dark"
                    android:paddingStart="@dimen/spacing_sm"
                    android:paddingEnd="@dimen/spacing_sm"
                    android:paddingTop="@dimen/spacing_xxs"
                    android:paddingBottom="@dimen/spacing_xxs"
                    app:layout_constraintTop_toTopOf="@id/btnBack"
                    app:layout_constraintBottom_toBottomOf="@id/btnBack"
                    app:layout_constraintEnd_toEndOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- ===== HERO SECTION ===== -->

            <!-- Envelope illustration -->
            <FrameLayout
                android:layout_width="96dp"
                android:layout_height="96dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="@dimen/spacing_xl">

                <!-- Outer glow ring -->
                <View
                    android:layout_width="96dp"
                    android:layout_height="96dp"
                    android:background="@drawable/bg_pulse_ring"
                    android:alpha="0.12"
                    android:layout_gravity="center" />

                <!-- Inner ring -->
                <View
                    android:layout_width="76dp"
                    android:layout_height="76dp"
                    android:background="@drawable/bg_pulse_ring"
                    android:alpha="0.20"
                    android:layout_gravity="center" />

                <!-- Envelope icon circle -->
                <androidx.cardview.widget.CardView
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:layout_gravity="center"
                    app:cardBackgroundColor="@color/card_inner_glow"
                    app:cardCornerRadius="28dp"
                    app:cardElevation="0dp">

                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_email"
                        android:contentDescription="@string/cd_email_icon"
                        android:colorFilter="@color/sos_core_red" />

                </androidx.cardview.widget.CardView>

            </FrameLayout>

            <!-- Screen label -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/email_capture_label"
                android:textSize="@dimen/text_micro"
                android:fontFamily="@font/poppins_medium"
                android:textColor="@color/sos_core_red"
                android:letterSpacing="0.12"
                android:textAllCaps="true"
                android:gravity="center"
                android:layout_marginTop="@dimen/spacing_lg" />

            <!-- Heading -->
            <TextView
                android:id="@+id/tvHeading"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/email_capture_heading"
                android:textSize="22sp"
                android:fontFamily="@font/poppins_extrabold"
                android:textColor="@color/white"
                android:gravity="center"
                android:lineSpacingMultiplier="1.2"
                android:layout_marginTop="@dimen/spacing_xs" />

            <!-- Explanation text -->
            <TextView
                android:id="@+id/tvExplanation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/email_capture_explanation"
                android:textSize="@dimen/text_caption"
                android:fontFamily="@font/poppins_regular"
                android:textColor="@color/text_muted"
                android:gravity="center"
                android:lineSpacingMultiplier="1.6"
                android:layout_marginTop="@dimen/spacing_sm" />

            <!-- Red divider -->
            <View
                android:layout_width="@dimen/divider_width"
                android:layout_height="@dimen/divider_height"
                android:background="@drawable/bg_red_divider"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="@dimen/spacing_lg" />

            <!-- ===== INCIDENT CONTEXT CARD ===== -->
            <!-- Reminds the user what was sent -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardIncidentContext"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_lg"
                app:cardBackgroundColor="@color/card_dark"
                app:cardCornerRadius="@dimen/card_radius_md"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="@dimen/spacing_md">

                    <!-- Green confirmed dot -->
                    <View
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:background="@drawable/bg_dot_green"
                        android:layout_marginEnd="@dimen/spacing_md" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/email_capture_alert_sent"
                            android:textSize="@dimen/text_caption"
                            android:fontFamily="@font/poppins_semibold"
                            android:textColor="@color/white" />

                        <TextView
                            android:id="@+id/tvIncidentContextSub"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/email_capture_alert_sub"
                            android:textSize="@dimen/text_micro"
                            android:fontFamily="@font/poppins_regular"
                            android:textColor="@color/text_muted"
                            android:layout_marginTop="@dimen/spacing_xxs" />

                    </LinearLayout>

                    <!-- Ref badge -->
                    <TextView
                        android:id="@+id/tvContextRef"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/post_sos_ref_placeholder"
                        android:textSize="@dimen/text_micro"
                        android:fontFamily="@font/poppins_semibold"
                        android:textColor="@color/text_muted"
                        android:background="@drawable/bg_badge_dark"
                        android:paddingStart="@dimen/spacing_sm"
                        android:paddingEnd="@dimen/spacing_sm"
                        android:paddingTop="@dimen/spacing_xxs"
                        android:paddingBottom="@dimen/spacing_xxs" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- ===== EMAIL INPUT SECTION ===== -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/email_capture_input_label"
                android:textSize="@dimen/text_caption"
                android:fontFamily="@font/poppins_semibold"
                android:textColor="@color/text_light"
                android:layout_marginTop="@dimen/spacing_xl" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilEmail"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/hint_email"
                app:boxBackgroundColor="@color/card_dark"
                app:boxStrokeColor="@color/rim_border"
                app:boxStrokeWidth="1dp"
                app:boxCornerRadiusTopStart="@dimen/card_radius_sm"
                app:boxCornerRadiusTopEnd="@dimen/card_radius_sm"
                app:boxCornerRadiusBottomStart="@dimen/card_radius_sm"
                app:boxCornerRadiusBottomEnd="@dimen/card_radius_sm"
                app:hintTextColor="@color/text_muted"
                app:startIconDrawable="@drawable/ic_email"
                app:startIconTint="@color/text_muted"
                android:layout_marginTop="@dimen/spacing_sm">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etEmail"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/btn_height_lg"
                    android:inputType="textEmailAddress"
                    android:textColor="@color/white"
                    android:textSize="@dimen/text_body"
                    android:fontFamily="@font/poppins_regular"
                    android:imeOptions="actionDone" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- What you'll receive note -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="@dimen/spacing_xs">

                <ImageView
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:src="@drawable/ic_check_circle"
                    android:contentDescription="@null"
                    android:layout_marginEnd="@dimen/spacing_xs" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/email_capture_receive_note"
                    android:textSize="@dimen/text_micro"
                    android:fontFamily="@font/poppins_regular"
                    android:textColor="@color/text_muted"
                    android:lineSpacingMultiplier="1.4" />

            </LinearLayout>

            <!-- ===== PRIMARY BUTTON: Send report to email ===== -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSendReport"
                android:layout_width="match_parent"
                android:layout_height="@dimen/btn_height_lg"
                android:text="@string/email_capture_btn_send"
                android:textSize="@dimen/text_button"
                android:fontFamily="@font/poppins_bold"
                android:textColor="@color/white"
                android:backgroundTint="@color/sos_core_red"
                app:cornerRadius="@dimen/btn_radius"
                app:icon="@drawable/ic_send"
                app:iconTint="@color/white"
                app:iconGravity="textStart"
                android:layout_marginTop="@dimen/spacing_xl" />

            <!-- ===== DIVIDER ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="@dimen/spacing_lg">

                <View
                    android:layout_width="0dp"
                    android:layout_height="0.5dp"
                    android:layout_weight="1"
                    android:background="@color/rim_border" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/or_divider"
                    android:textSize="@dimen/text_micro"
                    android:fontFamily="@font/poppins_regular"
                    android:textColor="@color/text_muted"
                    android:paddingStart="@dimen/spacing_md"
                    android:paddingEnd="@dimen/spacing_md" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="0.5dp"
                    android:layout_weight="1"
                    android:background="@color/rim_border" />

            </LinearLayout>

            <!-- ===== FINISH CREATING ACCOUNT SECTION ===== -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardCreateAccount"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_lg"
                app:cardBackgroundColor="@color/card_dark"
                app:cardCornerRadius="@dimen/card_radius_md"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_lg">

                    <!-- Account benefits -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/email_capture_account_title"
                        android:textSize="@dimen/text_caption"
                        android:fontFamily="@font/poppins_semibold"
                        android:textColor="@color/white"
                        android:layout_marginBottom="@dimen/spacing_sm" />

                    <!-- Benefit 1 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="@dimen/spacing_xs">

                        <View
                            android:layout_width="6dp"
                            android:layout_height="6dp"
                            android:background="@drawable/bg_dot_green"
                            android:layout_marginEnd="@dimen/spacing_sm" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/email_capture_benefit_1"
                            android:textSize="@dimen/text_micro"
                            android:fontFamily="@font/poppins_regular"
                            android:textColor="@color/text_muted" />

                    </LinearLayout>

                    <!-- Benefit 2 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="@dimen/spacing_xs">

                        <View
                            android:layout_width="6dp"
                            android:layout_height="6dp"
                            android:background="@drawable/bg_dot_green"
                            android:layout_marginEnd="@dimen/spacing_sm" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/email_capture_benefit_2"
                            android:textSize="@dimen/text_micro"
                            android:fontFamily="@font/poppins_regular"
                            android:textColor="@color/text_muted" />

                    </LinearLayout>

                    <!-- Benefit 3 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="@dimen/spacing_lg">

                        <View
                            android:layout_width="6dp"
                            android:layout_height="6dp"
                            android:background="@drawable/bg_dot_green"
                            android:layout_marginEnd="@dimen/spacing_sm" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/email_capture_benefit_3"
                            android:textSize="@dimen/text_micro"
                            android:fontFamily="@font/poppins_regular"
                            android:textColor="@color/text_muted" />

                    </LinearLayout>

                    <!-- Finish creating account button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnFinishAccount"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/btn_height_md"
                        android:text="@string/email_capture_btn_finish_account"
                        android:textSize="@dimen/text_button"
                        android:fontFamily="@font/poppins_semibold"
                        android:textColor="@color/white"
                        android:backgroundTint="@color/card_mid"
                        app:cornerRadius="@dimen/btn_radius"
                        app:strokeColor="@color/rim_border"
                        app:strokeWidth="1dp"
                        app:icon="@drawable/ic_person"
                        app:iconTint="@color/white"
                        app:iconGravity="textStart" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- ===== SKIP FOR NOW ===== -->
            <TextView
                android:id="@+id/tvSkip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/email_capture_skip"
                android:textSize="@dimen/text_caption"
                android:fontFamily="@font/poppins_medium"
                android:textColor="@color/text_muted"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="@dimen/spacing_lg"
                android:paddingTop="@dimen/spacing_sm"
                android:paddingBottom="@dimen/spacing_sm"
                android:clickable="true"
                android:focusable="true" />

            <!-- Privacy note -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/email_capture_privacy_note"
                android:textSize="@dimen/text_micro"
                android:fontFamily="@font/poppins_regular"
                android:textColor="@color/text_muted"
                android:gravity="center"
                android:lineSpacingMultiplier="1.5"
                android:layout_marginTop="@dimen/spacing_md"
                android:alpha="0.6" />

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>