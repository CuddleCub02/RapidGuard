<?xml version="1.0" encoding="utf-8"?>
<!-- RapidGuard | Reusable safety tip card -->
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/spacing_md"
    app:cardBackgroundColor="@color/card_dark"
    app:cardCornerRadius="@dimen/card_radius_md"
    app:cardElevation="0dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="@dimen/spacing_lg">

        <!-- Category badge -->
        <TextView
            android:id="@+id/tvTipCategory"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Personal Safety"
            android:textSize="@dimen/text_micro"
            android:fontFamily="@font/poppins_semibold"
            android:textColor="@color/sos_core_red"
            android:background="@drawable/bg_status_danger"
            android:paddingStart="@dimen/spacing_sm"
            android:paddingEnd="@dimen/spacing_sm"
            android:paddingTop="@dimen/spacing_xxs"
            android:paddingBottom="@dimen/spacing_xxs"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- Tip icon -->
        <ImageView
            android:id="@+id/ivTipIcon"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_shield_tip"
            android:contentDescription="@string/cd_tip_icon"
            app:layout_constraintTop_toTopOf="@id/tvTipCategory"
            app:layout_constraintBottom_toBottomOf="@id/tvTipCategory"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Tip title -->
        <TextView
            android:id="@+id/tvTipTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Tip title goes here"
            android:textSize="@dimen/text_caption"
            android:fontFamily="@font/poppins_semibold"
            android:textColor="@color/white"
            app:layout_constraintTop_toBottomOf="@id/tvTipCategory"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="@dimen/spacing_sm" />

        <!-- Tip body -->
        <TextView
            android:id="@+id/tvTipBody"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Tip body text goes here with actionable advice."
            android:textSize="@dimen/text_micro"
            android:fontFamily="@font/poppins_regular"
            android:textColor="@color/text_muted"
            android:lineSpacingMultiplier="1.5"
            app:layout_constraintTop_toBottomOf="@id/tvTipTitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="@dimen/spacing_xs" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.cardview.widget.CardView>