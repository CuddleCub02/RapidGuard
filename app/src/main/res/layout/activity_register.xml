<?xml version="1.0" encoding="utf-8"?>
<!-- RapidGuard | Screen 3: Register Screen | Group 41 -->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/registerRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient_radial"
    tools:context=".RegisterActivity">

    <!-- Subtle grid overlay -->
    <View
        android:id="@+id/gridOverlay"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@drawable/bg_grid_overlay"
        android:alpha="0.04"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Full scrollable form -->
    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:scrollbars="none"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="@dimen/spacing_lg"
            android:paddingEnd="@dimen/spacing_lg"
            android:paddingBottom="@dimen/spacing_xxl">

            <!-- Back button -->
            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_arrow_back"
                android:background="@drawable/bg_card_dark"
                android:contentDescription="@string/cd_back"
                android:padding="@dimen/spacing_sm"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                android:layout_marginTop="@dimen/spacing_xxl" />

            <!-- Screen label -->
            <TextView
                android:id="@+id/tvScreenLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/register_label"
                android:textSize="@dimen/text_micro"
                android:fontFamily="@font/poppins_medium"
                android:textColor="@color/sos_core_red"
                android:letterSpacing="0.12"
                android:textAllCaps="true"
                app:layout_constraintTop_toTopOf="@id/btnBack"
                app:layout_constraintBottom_toBottomOf="@id/btnBack"
                app:layout_constraintStart_toEndOf="@id/btnBack"
                android:layout_marginStart="@dimen/spacing_md" />

            <!-- Heading -->
            <TextView
                android:id="@+id/tvHeading"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="@string/register_heading"
                android:textSize="@dimen/text_heading"
                android:fontFamily="@font/poppins_bold"
                android:textColor="@color/white"
                android:lineSpacingMultiplier="1.2"
                app:layout_constraintTop_toBottomOf="@id/btnBack"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="@dimen/spacing_lg" />

            <!-- Subheading -->
            <TextView
                android:id="@+id/tvSubheading"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="@string/register_subheading"
                android:textSize="@dimen/text_body"
                android:fontFamily="@font/poppins_regular"
                android:textColor="@color/text_muted"
                app:layout_constraintTop_toBottomOf="@id/tvHeading"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="@dimen/spacing_xs" />

            <!-- Red divider -->
            <View
                android:id="@+id/redDivider"
                android:layout_width="@dimen/divider_width"
                android:layout_height="@dimen/divider_height"
                android:background="@drawable/bg_red_divider"
                app:layout_constraintTop_toBottomOf="@id/tvSubheading"
                app:layout_constraintStart_toStartOf="parent"
                android:layout_marginTop="@dimen/spacing_lg" />

            <!-- Full Name -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilFullName"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:hint="@string/hint_full_name"
                app:boxBackgroundColor="@color/card_dark"
                app:boxStrokeColor="@color/rim_border"
                app:boxStrokeWidth="1dp"
                app:boxCornerRadiusTopStart="@dimen/card_radius_sm"
                app:boxCornerRadiusTopEnd="@dimen/card_radius_sm"
                app:boxCornerRadiusBottomStart="@dimen/card_radius_sm"
                app:boxCornerRadiusBottomEnd="@dimen/card_radius_sm"
                app:hintTextColor="@color/text_muted"
                app:startIconDrawable="@drawable/ic_person"
                app:startIconTint="@color/text_muted"
                app:layout_constraintTop_toBottomOf="@id/redDivider"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="@dimen/spacing_xl">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etFullName"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/btn_height_lg"
                    android:inputType="textPersonName|textCapWords"
                    android:textColor="@color/white"
                    android:textSize="@dimen/text_body"
                    android:fontFamily="@font/poppins_regular"
                    android:imeOptions="actionNext" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Phone Number -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilPhone"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:hint="@string/hint_phone"
                app:boxBackgroundColor="@color/card_dark"
                app:boxStrokeColor="@color/rim_border"
                app:boxStrokeWidth="1dp"
                app:boxCornerRadiusTopStart="@dimen/card_radius_sm"
                app:boxCornerRadiusTopEnd="@dimen/card_radius_sm"
                app:boxCornerRadiusBottomStart="@dimen/card_radius_sm"
                app:boxCornerRadiusBottomEnd="@dimen/card_radius_sm"
                app:hintTextColor="@color/text_muted"
                app:startIconDrawable="@drawable/ic_phone"
                app:startIconTint="@color/text_muted"
                app:layout_constraintTop_toBottomOf="@id/tilFullName"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="@dimen/spacing_md">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etPhone"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/btn_height_lg"
                    android:inputType="phone"
                    android:textColor="@color/white"
                    android:textSize="@dimen/text_body"
                    android:fontFamily="@font/poppins_regular"
                    android:imeOptions="actionNext" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Email -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilEmail"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:hint="@string/hint_email"
                app:boxBackgroundColor="@color/card_dark"
                app:boxStrokeColor="@color/rim_border"
                app:boxStrokeWidth="1dp"
                app:boxCornerRadiusTopStart="@dimen/card_radius_sm"
                app:boxCornerRadiusTopEnd="@dimen/card_radius_sm"
                app:boxCornerRadiusBottomStart="@dimen/card_radius_sm"
                app:boxCornerRadiusBottomEnd="@dimen/card_radius_sm"
                app:hintTextColor="@color/text_muted"
                app:startIconDrawable="@drawable/ic_email"
                app:startIconTint="@color/text_muted"
                app:layout_constraintTop_toBottomOf="@id/tilPhone"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="@dimen/spacing_md">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etEmail"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/btn_height_lg"
                    android:inputType="textEmailAddress"
                    android:textColor="@color/white"
                    android:textSize="@dimen/text_body"
                    android:fontFamily="@font/poppins_regular"
                    android:imeOptions="actionNext" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Password -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilPassword"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:hint="@string/hint_password"
                app:boxBackgroundColor="@color/card_dark"
                app:boxStrokeColor="@color/rim_border"
                app:boxStrokeWidth="1dp"
                app:boxCornerRadiusTopStart="@dimen/card_radius_sm"
                app:boxCornerRadiusTopEnd="@dimen/card_radius_sm"
                app:boxCornerRadiusBottomStart="@dimen/card_radius_sm"
                app:boxCornerRadiusBottomEnd="@dimen/card_radius_sm"
                app:hintTextColor="@color/text_muted"
                app:startIconDrawable="@drawable/ic_lock"
                app:startIconTint="@color/text_muted"
                app:passwordToggleEnabled="true"
                app:passwordToggleTint="@color/text_muted"
                app:layout_constraintTop_toBottomOf="@id/tilEmail"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="@dimen/spacing_md">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etPassword"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/btn_height_lg"
                    android:inputType="textPassword"
                    android:textColor="@color/white"
                    android:textSize="@dimen/text_body"
                    android:fontFamily="@font/poppins_regular"
                    android:imeOptions="actionNext" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Password strength indicator -->
            <LinearLayout
                android:id="@+id/passwordStrengthRow"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="@dimen/spacing_xs"
                app:layout_constraintTop_toBottomOf="@id/tilPassword"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <!-- Strength bar segments -->
                <View
                    android:id="@+id/strengthBar1"
                    android:layout_width="0dp"
                    android:layout_height="3dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_strength_inactive"
                    android:layout_marginEnd="@dimen/spacing_xs" />
                <View
                    android:id="@+id/strengthBar2"
                    android:layout_width="0dp"
                    android:layout_height="3dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_strength_inactive"
                    android:layout_marginEnd="@dimen/spacing_xs" />
                <View
                    android:id="@+id/strengthBar3"
                    android:layout_width="0dp"
                    android:layout_height="3dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_strength_inactive"
                    android:layout_marginEnd="@dimen/spacing_xs" />
                <View
                    android:id="@+id/strengthBar4"
                    android:layout_width="0dp"
                    android:layout_height="3dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_strength_inactive" />

                <TextView
                    android:id="@+id/tvStrengthLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/strength_weak"
                    android:textSize="@dimen/text_micro"
                    android:fontFamily="@font/poppins_medium"
                    android:textColor="@color/text_muted"
                    android:layout_marginStart="@dimen/spacing_sm"
                    android:visibility="gone" />

            </LinearLayout>

            <!-- Confirm Password -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilConfirmPassword"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:hint="@string/hint_confirm_password"
                app:boxBackgroundColor="@color/card_dark"
                app:boxStrokeColor="@color/rim_border"
                app:boxStrokeWidth="1dp"
                app:boxCornerRadiusTopStart="@dimen/card_radius_sm"
                app:boxCornerRadiusTopEnd="@dimen/card_radius_sm"
                app:boxCornerRadiusBottomStart="@dimen/card_radius_sm"
                app:boxCornerRadiusBottomEnd="@dimen/card_radius_sm"
                app:hintTextColor="@color/text_muted"
                app:startIconDrawable="@drawable/ic_lock"
                app:startIconTint="@color/text_muted"
                app:passwordToggleEnabled="true"
                app:passwordToggleTint="@color/text_muted"
                app:layout_constraintTop_toBottomOf="@id/passwordStrengthRow"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="@dimen/spacing_md">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etConfirmPassword"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/btn_height_lg"
                    android:inputType="textPassword"
                    android:textColor="@color/white"
                    android:textSize="@dimen/text_body"
                    android:fontFamily="@font/poppins_regular"
                    android:imeOptions="actionDone" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Terms & Conditions checkbox -->
            <LinearLayout
                android:id="@+id/termsRow"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                app:layout_constraintTop_toBottomOf="@id/tilConfirmPassword"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="@dimen/spacing_lg">

                <CheckBox
                    android:id="@+id/cbTerms"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:buttonTint="@color/sos_core_red"
                    android:checked="false" />

                <TextView
                    android:id="@+id/tvTerms"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/register_terms"
                    android:textSize="@dimen/text_micro"
                    android:fontFamily="@font/poppins_regular"
                    android:textColor="@color/text_muted"
                    android:layout_marginStart="@dimen/spacing_sm" />

            </LinearLayout>

            <!-- Register button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRegister"
                android:layout_width="0dp"
                android:layout_height="@dimen/btn_height_lg"
                android:text="@string/btn_register"
                android:textSize="@dimen/text_button"
                android:fontFamily="@font/poppins_bold"
                android:textColor="@color/white"
                android:backgroundTint="@color/sos_core_red"
                app:cornerRadius="@dimen/btn_radius"
                app:layout_constraintTop_toBottomOf="@id/termsRow"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="@dimen/spacing_xl" />

            <!-- Already have account / login link -->
            <LinearLayout
                android:id="@+id/loginRow"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                app:layout_constraintTop_toBottomOf="@id/btnRegister"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="@dimen/spacing_lg">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/register_have_account"
                    android:textSize="@dimen/text_caption"
                    android:fontFamily="@font/poppins_regular"
                    android:textColor="@color/text_muted" />

                <TextView
                    android:id="@+id/tvLoginLink"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/register_login_link"
                    android:textSize="@dimen/text_caption"
                    android:fontFamily="@font/poppins_semibold"
                    android:textColor="@color/white"
                    android:clickable="true"
                    android:focusable="true"
                    android:layout_marginStart="@dimen/spacing_xs" />

            </LinearLayout>

            <!-- SOS shortcut card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardSOSShortcut"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/card_dark"
                app:cardCornerRadius="@dimen/card_radius_md"
                app:cardElevation="0dp"
                app:layout_constraintTop_toBottomOf="@id/loginRow"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="@dimen/spacing_xl">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="@dimen/spacing_lg">

                    <ImageView
                        android:id="@+id/ivSOSIcon"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/ic_shield_sos"
                        android:contentDescription="@string/cd_sos_shortcut"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent" />

                    <TextView
                        android:id="@+id/tvSOSShortcutTitle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="@string/sos_shortcut_title"
                        android:textSize="@dimen/text_button"
                        android:fontFamily="@font/poppins_semibold"
                        android:textColor="@color/white"
                        app:layout_constraintTop_toTopOf="@id/ivSOSIcon"
                        app:layout_constraintStart_toEndOf="@id/ivSOSIcon"
                        app:layout_constraintEnd_toStartOf="@id/btnSOSShortcut"
                        android:layout_marginStart="@dimen/spacing_md" />

                    <TextView
                        android:id="@+id/tvSOSShortcutSub"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="@string/sos_shortcut_sub"
                        android:textSize="@dimen/text_micro"
                        android:fontFamily="@font/poppins_regular"
                        android:textColor="@color/text_muted"
                        app:layout_constraintTop_toBottomOf="@id/tvSOSShortcutTitle"
                        app:layout_constraintStart_toEndOf="@id/ivSOSIcon"
                        app:layout_constraintEnd_toStartOf="@id/btnSOSShortcut"
                        android:layout_marginStart="@dimen/spacing_md" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSOSShortcut"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/btn_sos_short"
                        android:textSize="@dimen/text_micro"
                        android:fontFamily="@font/poppins_bold"
                        android:textColor="@color/white"
                        android:backgroundTint="@color/sos_core_red"
                        android:paddingStart="@dimen/spacing_md"
                        android:paddingEnd="@dimen/spacing_md"
                        app:cornerRadius="@dimen/btn_radius"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent" />

                </androidx.constraintlayout.widget.ConstraintLayout>
            </androidx.cardview.widget.CardView>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>